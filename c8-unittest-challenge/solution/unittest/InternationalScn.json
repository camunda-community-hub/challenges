{
  "name": "International Transaction",
  "processId": "Tran_BOA",
  "serverType": "Camunda_8",
  "typeScenario": "UNIT",
  "versionTest": "1.0",
  "description": "International transaction",
  "executions": [
    {
      "name": "National Transaction",
      "policy": "STOPATFIRSTERROR",
      "waitForOperateImport": 5,
      "steps": [
        {
          "type": "STARTEVENT",
          "taskId": "Start_Transaction",
          "processId": "Tran_BOA",
          "variables": {
            "identification": "Jan.Fisher",
            "amount": 3530.44
          }
        },
        {
          "taskId": "Activity_CheckIdentity",
          "jobType": "check-identity",
          "type": "SERVICETASK",
          "description": "Pass the identity"
        },
        {
          "taskId": "Activity_CheckTransaction",
          "jobType": "check-transaction",
          "type": "SERVICETASK",
          "description": "Pass the Check transaction",
          "variables": {
            "transaction": "INTER"
          }
        },
        {
          "taskId": "Activity_WiseTransfer",
          "jobType": "wise-registration",
          "type": "SERVICETASK",
          "description": "Create the Wise transaction",
          "variables": {
            "transactionId": "1234567"
          }
        },
        {
          "taskId": "Event_WiseAccepted",
          "correlationKey": "1234567",
          "messageName" : "msg-wise-accepted",
          "type": "MESSAGE",
          "description": "Send the message"
        },
        {
          "taskId": "Activity_TransactionWise",
          "jobType": "wise-transaction",
          "type": "SERVICETASK",
          "description": "Wise transaction",
          "variables": {
            "transactionStatus": "DONE"
          }
        },
        {
          "taskId": "Activity_NotifyCustomerSuccess",
          "jobType": "notify-customer",
          "type": "SERVICETASK",
          "description": "Customer is notified with the success of the transaction"
        }
      ],
      "verifications": {
        "activities": [
          {
            "taskId": "Activity_CheckIdentity",
            "type": "TASK",
            "description": "Pass the identity"
          },
          {
            "taskId": "Activity_CheckTransaction",
            "type": "TASK",
            "description": "Pass the Check transaction"
          },
          {
            "taskId": "Activity_WiseTransfer",
            "type": "TASK",
            "description": "Flow go to the International transaction"
          },
          {
            "taskId": "Event_WiseAccepted",
            "type": "INTERMEDIATE_CATCH_EVENT",
            "description": "Customer is notified with the success of the transaction"
          },
          {
            "taskId": "Activity_TransactionWise",
            "type": "TASK",
            "description": "Customer is notified with the success of the transaction"
          },
          {
            "taskId": "Activity_NotifyCustomerSuccess",
            "type": "TASK",
            "description": "Customer is notified with the success of the transaction"
          },
          {
            "type": "ENDEVENT",
            "taskId": "End_Transaction"
          }
        ],
        "variables": [
          {
            "description": "Transaction is validate",
            "name": "transactionStatus",
            "value": "DONE"
          }
        ],
        "performances": []
      }
    }
  ]
}